{
    "manifest_version": 3,
    "name": "Bin Extension",
    "version": "1.0",
    "description": "Quick access to your favorite websites with popup, search, and sync features",
    "key": "",
    "icons": {
        "16": "images/icon-16.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "history",
        "storage"
    ],
    "host_permissions": [
        "https://api.ipify.org/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Default Title Placeholder",
        "default_popup": "popup.html"
    },
    "default_locale": "en",
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Y",
                "mac": "Command+B"
            },
            "description": "Activate the extension popup"
        },
        "quick_search": {
            "suggested_key": {
                "default": "Alt+S",
                "mac": "Command+S"
            },
            "description": "Quick search selected text"
        },
        "direct_search": {
            "suggested_key": {
                "default": "Alt+Shift+S",
                "mac": "Command+Shift+S"
            },
            "description": "Direct search with DuckDuckGo"
        }
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["quickSearch.js"],
            "run_at": "document_end"
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "bin-extension@example.com",
            "strict_min_version": "109.0"
        }
    }
}
